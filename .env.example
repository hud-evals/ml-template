# GitHub PAT for installing hud-sdlc-lib (private) during Docker build
# and local `uv sync`. Provided to you by HUD.
LIB_GITHUB_PAT=given-to-you-by-hud

# Override the environment name / image tag used by `hud build` and `hud deploy`.
# Falls back to the name in pyproject.toml if unset.
# ENV_NAME=

# Taskset name for `uv run sync-tasks`.
# Set here or pass --taskset flag.
# TASKSET_NAME=
